---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/tags-list.css';

type TagCount = { tag: string; count: number };

const posts = (await getCollection('posts')) as CollectionEntry<'posts'>[];
// Sort posts by pubDate descending (most recent first)
posts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate).getTime();
  const dateB = new Date(b.data.pubDate).getTime();
  return dateB - dateA;
});
const tagCounts: Record<string, TagCount & { latestDate: number }> = {};
posts.forEach((post: CollectionEntry<'posts'>) => {
  if (Array.isArray(post.data.tags)) {
    post.data.tags.forEach((tag: string) => {
      const tagLower = tag.toLowerCase();
      if (!tagCounts[tagLower]) {
        tagCounts[tagLower] = { tag, count: 0, latestDate: new Date(post.data.pubDate).getTime() };
      }
      tagCounts[tagLower].count++;
      // Always keep the latest date for this tag
      if (new Date(post.data.pubDate).getTime() > tagCounts[tagLower].latestDate) {
        tagCounts[tagLower].latestDate = new Date(post.data.pubDate).getTime();
      }
    });
  }
});
// Sort tags alphabetically ascending by tag name
const allTags: TagCount[] = Object.values(tagCounts)
  .sort((a, b) => a.tag.localeCompare(b.tag));
---

<BaseLayout frontmatter={{ title: 'All Tags' }}>
  <section class="tag-page content-padding">
    <h2>All Tags</h2>
    {
      allTags.length === 0 ? (
        <p>No tags found.</p>
      ) : (
        <>
          <input
            id="tag-filter"
            type="text"
            placeholder="Filter tags..."
            class="tag-filter-input"
          />
          <script is:inline>
            const filterInput = document.getElementById('tag-filter');
            if (filterInput) {
              filterInput.addEventListener('input', function(e) {
                const target = e.target;
                if (!(target instanceof HTMLInputElement)) return;
                const val = target.value.toLowerCase();
                document.querySelectorAll('.tagged-posts-list li').forEach(el => {
                  if (el.textContent.toLowerCase().includes(val)) {
                    el.style.display = '';
                  } else {
                    el.style.display = 'none';
                  }
                });
              });
            }
          </script>
          <ul class="tagged-posts-list all-tags-list">
            {allTags.map(({ tag, count }) => (
              <li>
                <a
                  href={`/tags/${encodeURIComponent(tag.toLowerCase())}/`}
                  class="all-tags-link"
                >
                  #{tag}
                </a>
                <span style="margin-left: 0.5em;">
                  ({count} post{count !== 1 ? 's' : ''})
                </span>
              </li>
            ))}
          </ul>
        </>
      )
    }
  </section>
</BaseLayout>

---
import type { Page } from 'astro';
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/posts-list.css';
import PostPreview from '../../components/PostPreview.astro';

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const posts = await getCollection('posts', ({ data }: { data: any }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });
  posts.sort(
    (a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

  return paginate(posts, { pageSize: 9 });
}

// All paginated data is passed on the "page" prop
type Props = { page: Page<CollectionEntry<'posts'>> };
const { page } = Astro.props;
const posts = page.data;
const pageTitle = 'All posts';
const pageMeta = {
  title: 'Site | ' + pageTitle,
  description: 'All blog posts in one place',
  imageUrl: '/default-social.png',
};
---

<BaseLayout pageMeta={pageMeta}>
  <section class="post-list">
    <h2 class="content-padding">{pageTitle}</h2>
    <div class="post-grid content-padding">
      {
        posts.map(post => (
          <PostPreview
            title={post.data.title}
            pubDate={post.data.pubDate}
            excerpt={post.data.description}
            image={post.data.image}
            slug={post.slug || post.id}
          />
        ))
      }
    </div>
  </section>
  <section class="pagination">
    <nav aria-label="Pagination">
      <div class="content-padding">
        {
          page.url.prev && (
            <a
              href={page.url.prev}
              aria-label={`Go to page ${page.currentPage - 1} of ${page.lastPage}`}
            >
              Prev
            </a>
          )
        }
        <span aria-current="page">
          &nbsp;Page {page.currentPage} of {page.lastPage}&nbsp;
        </span>
        {
          page.url.next && (
            <a
              href={page.url.next}
              aria-label={`Go to page ${page.currentPage + 1} of ${page.lastPage}`}
            >
              Next
            </a>
          )
        }
      </div>
    </nav>
  </section>
</BaseLayout>

---
import MarkdownPageLayout from '../layouts/MarkdownPageLayout.astro';
import { getEntry, render } from 'astro:content';
import '../styles/category-pages.css';
const rest = await getEntry('pages', 'rest');
const { Content } = rest ? await render(rest) : { Content: null };
const pageMeta = {
  title: rest?.data.title,
  description: rest?.data.description,
  imageUrl: '/default-social.png',
};
---

<MarkdownPageLayout frontmatter={rest?.data} pageMeta={pageMeta}>
  {Content && <Content />}
</MarkdownPageLayout>

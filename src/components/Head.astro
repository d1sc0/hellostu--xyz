---
import { SEO } from 'astro-seo';
import fs from 'node:fs';
const { frontmatter, pageMeta } = Astro.props;
import { AstroFont } from 'astro-font';
const siteURL = Astro.site?.toString() || '';

// Determine the slug/id for the OG image (prefer id, fallback to slug, fallback to url path)
const urlPath = Astro.url?.pathname?.replace(/\/$/, '') || '';
const urlId =
  frontmatter?.id || frontmatter?.slug || urlPath.split('/').pop() || 'index';

let ogImage = `${siteURL}generated_social_images/${urlId}.png`;
const ogImagePath = `public/generated_social_images/${urlId}.png`;
if (!fs.existsSync(ogImagePath)) {
  ogImage = `${siteURL}default_social.png`;
}

const title =
  (frontmatter?.title && `HelloStu | ${frontmatter.title}`) ||
  (pageMeta?.title && `HelloStu | ${pageMeta.title}`) ||
  'HelloStu';
const description = frontmatter?.description || pageMeta?.description || '';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': frontmatter?.title ? 'Article' : 'WebPage',
  headline: title,
  description: description,
  image: ogImage,
  author: {
    '@type': 'Person',
    name: 'Stuart Mackenzie',
  },
  ...(frontmatter?.pubDate && { datePublished: frontmatter.pubDate }),
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': siteURL.replace(/\/$/, '') + (Astro.url?.pathname || '/'),
  },
};
---

<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link
    rel="canonical"
    href={siteURL.replace(/\/$/, '') + (Astro.url?.pathname || '/')}
  />
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(jsonLd)}
  />
  <meta name="viewport" content="width=device-width" />
  <meta name="generator" content={Astro.generator} />
  <AstroFont
    config={[
      {
        src: [],
        name: 'Lexend',
        // Google Fonts URL
        googleFontsURL:
          'https://fonts.googleapis.com/css2?family=Lexend:wght@100..900',
        preload: true,
        display: 'swap',
        fallback: 'sans-serif',
      },
    ]}
  />
  <AstroFont
    config={[
      {
        src: [],
        name: 'Gochi Hand',
        // Google Fonts URL
        googleFontsURL: 'https://fonts.googleapis.com/css2?family=Gochi+Hand',
        preload: true,
        display: 'swap',
        fallback: 'sans-serif',
      },
    ]}
  />
  <SEO
    title={title}
    description={description}
    openGraph={{
      basic: {
        title: title,
        type: frontmatter !== undefined ? 'article' : 'website',
        image: ogImage,
      },
      optional: {
        description: description,
      },
      article: { authors: ['Stuart Mackenzie'] },
    }}
    twitter={{
      creator: '@_disco',
      card: 'summary_large_image',
      title: title,
      image: ogImage,
      description: description,
    }}
  />
  <script
    defer
    src="https://cloud.umami.is/script.js"
    data-website-id="654a48c1-5908-4f15-9c11-61de28477192"></script>
  <script src="/scripts/apexchart-loader.js" is:inline></script>
</head>

---
import '../styles/post-preview.css';
const { title, pubDate, excerpt, slug } = Astro.props;
const formattedDate = pubDate
  ? new Date(pubDate).toLocaleDateString('en-UK', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    })
  : '';
const previewImage = slug
  ? `/generated_preview_images/${slug}.png`
  : '/preview-background.png';
---

<article class="post-preview">
  <a href={slug ? `/posts/${slug}/` : '#'} class="post-preview__image-link">
    <img
      class="post-preview__image"
      src={previewImage}
      alt={title}
      loading="lazy"
      onerror="this.onerror=null;this.src='/default-preview.png';"
    />
  </a>
  <div class="post-preview__content">
    <h3 class="post-preview__title">
      <a href={slug ? `/posts/${slug}/` : '#'}>{title}</a>
    </h3>
    <p class="post-preview__date">{formattedDate}</p>
    <p class="post-preview__excerpt">{excerpt}</p>
    <a class="post-preview__read-more" href={slug ? `/posts/${slug}/` : '#'}
      >Read more...</a
    >
  </div>
</article>

---
import { type CollectionEntry, getCollection } from 'astro:content';
import '../styles/tags-list.css';

type TagCount = { tag: string; count: number; latestDate: number };
const posts = (await getCollection('posts')) as CollectionEntry<'posts'>[];
posts.sort((a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) => {
  const dateA = new Date(a.data.pubDate).getTime();
  const dateB = new Date(b.data.pubDate).getTime();
  return dateB - dateA;
});
const tagCounts: Record<string, TagCount> = {};
posts.forEach((post: CollectionEntry<'posts'>) => {
  if (Array.isArray(post.data.tags)) {
    (post.data.tags as string[]).forEach((tag: string) => {
      const tagLower = tag.toLowerCase();
      if (!tagCounts[tagLower]) {
        tagCounts[tagLower] = { tag, count: 0, latestDate: new Date(post.data.pubDate).getTime() };
      }
      tagCounts[tagLower].count++;
      if (new Date(post.data.pubDate).getTime() > tagCounts[tagLower].latestDate) {
        tagCounts[tagLower].latestDate = new Date(post.data.pubDate).getTime();
      }
    });
  }
});
const allTags = Object.values(tagCounts) as TagCount[];
allTags.sort((a, b) => a.tag.localeCompare(b.tag));
---

<section class="tag-page">
  <h2>All Tags</h2>
  {
    allTags.length === 0 ? (
      <p>No tags found.</p>
    ) : (
      <>
        <div class="tag-controls">
          <input
            id="tag-filter-input"
            type="text"
            placeholder="Filter tags..."
            class="tag-filter-input"
          />
          <div class="tag-sort-controls" role="group" aria-label="Sort tags">
            <button
              type="button"
              class="tag-sort-btn"
              data-tag-sort="tag"
              data-label="A-Z"
              aria-label="Sort tags alphabetically"
            >
              A-Z
            </button>
            <button
              type="button"
              class="tag-sort-btn"
              data-tag-sort="count"
              data-label="Count"
              aria-label="Sort tags by count"
            >
              Count
            </button>
          </div>
        </div>
        <ul class="tagged-posts-list all-tags-list">
          {allTags.map((tag) => (
            <li data-tag={tag.tag.toLowerCase()} data-count={String(tag.count)}>
              <a href={`/tags/${tag.tag.toLowerCase()}/`} class="all-tags-link">{tag.tag} ({tag.count})</a>
            </li>
          ))}
        </ul>
        <p id="tag-filter-empty" class="tag-filter-empty" hidden>
          No tags match that filter.
        </p>
        <script is:inline>
          const filterInput = document.getElementById('tag-filter-input');
          const tagList = document.querySelector('.tagged-posts-list');
          const emptyState = document.getElementById('tag-filter-empty');
          const sortButtons = Array.from(
            document.querySelectorAll('[data-tag-sort]'),
          );

          if (
            filterInput instanceof HTMLInputElement &&
            tagList instanceof HTMLUListElement
          ) {
            const collator = new Intl.Collator(undefined, {
              sensitivity: 'base',
              numeric: true,
            });

            let sortBy = 'tag';
            let sortDir = 'asc';

            const updateSortButtons = () => {
              sortButtons.forEach(button => {
                if (!(button instanceof HTMLButtonElement)) return;
                const label = button.dataset.label || button.textContent || '';
                const isActive = button.dataset.tagSort === sortBy;

                button.classList.toggle('tag-sort-btn--active', isActive);
                button.textContent = isActive
                  ? `${label} ${sortDir === 'asc' ? '↑' : '↓'}`
                  : label;
              });
            };

            const applyListState = () => {
              const query = filterInput.value.toLowerCase().trim();
              const items = Array.from(tagList.querySelectorAll('li'));

              items.sort((a, b) => {
                if (sortBy === 'count') {
                  const countA = Number(a.dataset.count || '0');
                  const countB = Number(b.dataset.count || '0');
                  return sortDir === 'asc' ? countA - countB : countB - countA;
                }

                const tagA = a.dataset.tag || '';
                const tagB = b.dataset.tag || '';
                return sortDir === 'asc'
                  ? collator.compare(tagA, tagB)
                  : collator.compare(tagB, tagA);
              });

              items.forEach(item => tagList.appendChild(item));

              let visibleCount = 0;
              items.forEach(item => {
                const text = (item.textContent || '').toLowerCase();
                const isVisible = text.includes(query);

                item.style.display = isVisible ? '' : 'none';
                if (isVisible) visibleCount += 1;
              });

              if (emptyState) {
                emptyState.hidden = visibleCount !== 0;
              }

              updateSortButtons();
            };

            filterInput.addEventListener('input', applyListState);

            sortButtons.forEach(button => {
              if (!(button instanceof HTMLButtonElement)) return;
              button.addEventListener('click', () => {
                const nextSort = button.dataset.tagSort || 'tag';

                if (nextSort === sortBy) {
                  sortDir = sortDir === 'asc' ? 'desc' : 'asc';
                } else {
                  sortBy = nextSort;
                  sortDir = 'asc';
                }

                applyListState();
              });
            });

            applyListState();
          }
        </script>
      </>
    )
  }
</section>

---
// Usage example:
// import CategoryCards from '../../components/CategoryCards.astro';
// <CategoryCards />
import { getEntry, getCollection } from 'astro:content';
import '../styles/category-cards.css';

const work = await getEntry('pages', 'work');
const rest = await getEntry('pages', 'rest');
const play = await getEntry('pages', 'play');

// Count posts per category
const posts = await getCollection('posts');
const categoryCounts = { Work: 0, Rest: 0, Play: 0 };
for (const post of posts) {
  if (post.data.category && categoryCounts[post.data.category] !== undefined) {
    categoryCounts[post.data.category]++;
  }
}
const totalPosts = Object.values(categoryCounts).reduce((a, b) => a + b, 0);

// Remove any usage of PieChart and SVG injection in the card rendering.
const categories = [
  {
    label: 'Work',
    slug: 'work',
    description: work?.data.description,
    href: '/work/',
    count: categoryCounts.Work,
    color: 'var(--color-accent)',
    restColor: 'var(--color-line)',
  },
  {
    label: 'Rest',
    slug: 'rest',
    description: rest?.data.description,
    href: '/rest/',
    count: categoryCounts.Rest,
    color: 'var(--color-link)',
    restColor: 'var(--color-line)',
  },
  {
    label: 'Play',
    slug: 'play',
    description: play?.data.description,
    href: '/play/',
    count: categoryCounts.Play,
    color: 'var(--color-text)',
    restColor: 'var(--color-line)',
  },
];
---

<section class="category-cards" aria-labelledby="category-cards-heading">
  <h2 id="category-cards-heading" class="category-cards__heading">
    Categories
  </h2>

  <div class="category-cards__grid">
    {
      categories.map((category, idx) => (
        <article class="category-cards__card">
          <a
            class={`category-cards__card-media category-cards__plant-link plant--${category.slug}`}
            href={category.href}
            aria-label={`Go to ${category.label} category`}
            tabIndex="0"
          />

          <div class="category-cards__card-body">
            <h4 class="category-cards__card-title">{category.label}</h4>
            <p class="category-cards__card-description">
              {category.description}
            </p>
            <a class="category-cards__card-link" href={category.href}>
              Read more
            </a>
          </div>
        </article>
      ))
    }
  </div>
</section>

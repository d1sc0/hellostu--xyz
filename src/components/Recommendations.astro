---
import { getCollection } from 'astro:content';
import recommendationsData from '../data/recommendations.json';
import '../styles/recommendations.css';

const { currentSlug } = Astro.props;
// Get the recommendations for this specific post
const relatedIds = recommendationsData[currentSlug] || [];

// Fetch the full post details for the recommended IDs
const allPosts = await getCollection('posts');
const relatedPosts = relatedIds
  .map(rec => {
    const post = allPosts.find(p => p.id === rec.id);
    return {
      post,
      justification: rec.justification,
      justificationAlt: rec.justificationAlt,
    };
  })
  .filter(item => item.post); // Filter out any missing posts

const getPirateCategory = (category) => {
  const lowerCat = category?.toLowerCase();
  if (lowerCat === 'work') return "Swabbin' the Decks ☠️";
  if (lowerCat === 'rest') return "Restin' Yer Bones 🛌";
  if (lowerCat === 'play') return "Carousin' for Fun 🎉";
  return category;
};
---

{
  relatedPosts.length > 0 && (
    <section class="recommendations content-padding">
      <h3 class="recommendations__title">
        What to read next
        <label class="recommendations__easter-egg" aria-label="Toggle Pirate Mode" title="Toggle Pirate Mode">
          <input type="checkbox" id="rec-mode-toggle" />
          <span class="emoji-books">📚</span>
          <span class="emoji-pirate">🏴‍☠️</span>
        </label>
      </h3>
      <ul class="recommendations__list">
        {relatedPosts.map(({ post, justification, justificationAlt }) => (
          <li class="recommendations__item">
            <a href={`/posts/${post.id}/`} class="recommendations__link">
              <strong>{post.data.title}</strong>
            </a>
            {post.data.category && (
              <a
                href={`/${encodeURIComponent(post.data.category.toLowerCase())}/`}
                class="recommendations__category"
                data-primary={post.data.category}
                data-alt={getPirateCategory(post.data.category)}
              >
                {post.data.category}
              </a>
            )}
            <p class="recommendations__justification" data-primary={justification} data-alt={justificationAlt || ''}>
              {justification}
            </p>
          </li>
        ))}
      </ul>
    </section>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const toggle = document.getElementById('rec-mode-toggle') as HTMLInputElement;
        if (!toggle) return;

        toggle.addEventListener('change', (e) => {
          const isAltMode = (e.target as HTMLInputElement).checked;
          
          document.querySelectorAll('.recommendations__justification, .recommendations__category').forEach(el => {
            const primaryText = el.getAttribute('data-primary');
            const altText = el.getAttribute('data-alt');
            
            if (isAltMode && altText) {
              el.textContent = altText;
            } else if (!isAltMode && primaryText) {
              el.textContent = primaryText;
            }
          });
        });
      });
    </script>
  )
}

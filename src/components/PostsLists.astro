---
// Usage: <PostsLists category="Work" />
import { type CollectionEntry, getCollection } from 'astro:content';
import '../styles/posts-lists.css';

interface Props {
  category?: string;
}

const { category } = Astro.props as Props;

const posts = (await getCollection('posts', ({ data }) => {
  const isDraft = import.meta.env.PROD ? data.draft !== true : true;
  if (!category) return isDraft;
  return data.category === category && isDraft;
})) as CollectionEntry<'posts'>[];

// Group posts by year
const postsByYear = posts.reduce(
  (acc, post) => {
    const year = new Date(post.data.pubDate).getFullYear();
    if (!acc[year]) acc[year] = [];
    acc[year].push(post);
    return acc;
  },
  {} as Record<number, CollectionEntry<'posts'>[]>,
);

const sortedYears = Object.keys(postsByYear)
  .map(Number)
  .sort((a, b) => b - a); // Most recent year first
---

<section class="posts" aria-labelledby="posts-heading">
  <h2 id="posts-heading" class="posts__heading">
    {category} Posts
  </h2>

  {
    posts.length === 0 ? (
      <p class="posts__empty">No posts in this category yet.</p>
    ) : (
      sortedYears.map((year, idx) => {
        const isLast = idx === sortedYears.length - 1;
        return (
          <div class="posts__table-wrap" key={year}>
            <h4 class="posts__year">{year}</h4>
            <div class="posts__list">
              {postsByYear[year]
                .sort(
                  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
                )
                .map(post => (
                  <div class="posts__row" key={post.id}>
                    <div class="posts__col posts__col--date">
                      {post.data.pubDate.toLocaleDateString('en-GB', {
                        day: '2-digit',
                        month: 'short',
                      })}
                    </div>
                    <div class="posts__col posts__col--title">
                      <a href={`/posts/${post.id}/`}>{post.data.title}</a>
                      {Array.isArray(post.data.tags) &&
                      post.data.tags.length > 0 ? (
                        <p class="posts__tags-row">
                          {post.data.tags.map(tag => (
                            <a
                              class="posts__tag"
                              key={tag}
                              href={`/tags/${encodeURIComponent(tag.toLowerCase())}/`}
                            >
                              #{tag}
                            </a>
                          ))}
                        </p>
                      ) : null}
                    </div>
                  </div>
                ))}
            </div>
            {!isLast && (
              <p class="toplink content-padding">
                <a href="#top" aria-label="Back to top">
                  <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                    focusable="false"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M12 19V7" />
                    <path d="M6 12l6-6 6 6" />
                    <path d="M5 4h14" />
                  </svg>
                </a>
              </p>
            )}
          </div>
        );
      })
    )
  }
</section>

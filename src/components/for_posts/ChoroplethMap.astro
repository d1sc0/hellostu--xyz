---
import 'leaflet/dist/leaflet.css';
const { id = 'map', mapAlign = '', mapConfig } = Astro.props;
---

<!--
  Generic ChoroplethMap component for Leaflet choropleth maps.
  Props:
    - id: DOM id for the map container (default 'map')
    - mapAlign: CSS class for layout
    - mapConfig: object containing:
        - geojsonData: GeoJSON FeatureCollection
        - center: [lat, lng]
        - zoom: number
        - tileUrl: string
        - tileAttribution: string
        - styleProp: string (property to color by)
        - getColorStops: array of stops for legend/colors
        - getColor: function as string (serialized)
        - legendTitle: string
        - infoTitle: string
        - infoValue: function as string (serialized)
        - legendPosition: string (default 'topleft')
        - attribution: string (HTML)
-->
<div class={mapAlign}>
  <div id={id} class="choropleth-map" data-config={JSON.stringify(mapConfig)}>
  </div>
</div>
<script type="module" src="/src/components/for_posts/choropleth-map-loader.js"
></script>
<style>
  .leaflet-container {
    max-width: 100%;
    max-height: 100%;
  }
  .choropleth-map {
    min-height: 500px;
    width: 100%;
  }
  .mapFull {
    padding: 10px;
    width: 100%;
    height: auto;
    border: 1px black solid;
    margin-bottom: 0rem;
    border-radius: 0.3rem;
  }
  :global(.info) {
    padding: 6px 8px;
    font:
      14px/16px Arial,
      Helvetica,
      sans-serif;
    background: white;
    background: rgba(255, 255, 255, 0.8);
    box-shadow: 0 0 15px rgba(0, 0, 0, 0.2);
    border-radius: 5px;
  }
  .info h4 {
    margin: 0 0 5px;
    color: #777;
  }
  .legend {
    text-align: left;
    line-height: 18px;
    color: #555;
  }
  :global(.legend-swatch) {
    width: 18px;
    height: 18px;
    display: inline-block;
    margin-right: 8px;
    opacity: 0.7;
    border: 1px solid #999;
    vertical-align: middle;
    box-sizing: border-box;
    background-clip: padding-box;
  }
</style>

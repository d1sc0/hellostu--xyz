---
// Usage:
// import MdxImageGallery from '../../components/MdxImageGallery.astro';
//
// <MdxImageGallery gallery="clean-and-rebuild" />
// <MdxImageGallery gallery="clean-and-rebuild" heading="Project gallery" showCaptions={true} />
// <MdxImageGallery gallery="clean-and-rebuild" linkMode="full-image" imageHeight="12rem" />
// <MdxImageGallery gallery="clean-and-rebuild" imageHeightMobile="8rem" imageHeightDesktop="12rem" />
// <MdxImageGallery gallery="clean-and-rebuild" showHeading={false} />
//
// Authoring note:
// If a post uses only this component and should still appear in the home image stream
// or drive OG image generation, set optional `featureImage` in that post frontmatter.

import fs from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import YAML from 'yaml';
import '../styles/mdx-image-gallery.css';

interface Props {
  gallery: string;
  heading?: string;
  showHeading?: boolean;
  showCaptions?: boolean;
  linkMode?: 'none' | 'full-image' | 'lightbox';
  imageHeight?: string;
  imageHeightMobile?: string;
  imageHeightDesktop?: string;
}

type GalleryImage = {
  src: string;
  alt?: string;
  caption?: string;
};

type GalleryEntry = {
  id: string;
  title?: string;
  images?: GalleryImage[];
};

type GalleryFile = {
  galleries?: GalleryEntry[];
};

type ResolvedGalleryImage = {
  image: ImageMetadata;
  alt: string;
  caption?: string;
};

const {
  gallery,
  heading,
  showHeading = true,
  showCaptions = false,
  linkMode = 'none',
  imageHeight = '10rem',
  imageHeightMobile,
  imageHeightDesktop,
} = Astro.props as Props;

let lightboxIndex: number | null = null;

const resolvedImageHeightMobile = imageHeightMobile || imageHeight;
const resolvedImageHeightDesktop = imageHeightDesktop || imageHeight;

const imageModules = import.meta.glob(
  '/src/assets/uploaded_images/**/*.{avif,gif,jpeg,jpg,png,webp}',
  {
    eager: true,
    import: 'default',
  },
) as Record<string, ImageMetadata>;

const imageByRelativePath = new Map<string, ImageMetadata>();
const imageByBaseName = new Map<string, ImageMetadata>();

for (const [assetPath, metadata] of Object.entries(imageModules)) {
  const relativePath = assetPath.replace('/src/assets/uploaded_images/', '');
  imageByRelativePath.set(relativePath, metadata);

  const baseName = path.basename(relativePath);
  if (!imageByBaseName.has(baseName)) {
    imageByBaseName.set(baseName, metadata);
  }
}

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const galleriesPath = path.join(process.cwd(), 'src/content/galleries.yaml');
const galleriesDir = path.dirname(galleriesPath);

let galleryEntries: GalleryEntry[] = [];
let loadError = '';

if (fs.existsSync(galleriesPath)) {
  try {
    const rawYaml = fs.readFileSync(galleriesPath, 'utf8');
    const parsed = YAML.parse(rawYaml) as GalleryFile;
    if (Array.isArray(parsed?.galleries)) {
      galleryEntries = parsed.galleries;
    }
  } catch (error) {
    loadError =
      error instanceof Error ? error.message : 'Unknown gallery parsing error.';
  }
} else {
  loadError = 'Gallery manifest file does not exist.';
}

function normalizeImageRef(src: string): {
  relativePath: string;
  baseName: string;
} {
  const withoutQueryOrHash = src.split('?')[0].split('#')[0];
  const normalized = decodeURIComponent(withoutQueryOrHash).replace(/\\/g, '/');
  const resolvedFromGalleryFile = path.resolve(galleriesDir, normalized);
  const resolvedFromGalleryRoot = path.resolve(
    process.cwd(),
    'src/content',
    normalized,
  );
  const marker = 'assets/uploaded_images/';
  const markerIndex = normalized.indexOf(marker);

  const relativePath = (() => {
    if (markerIndex >= 0) {
      return normalized.slice(markerIndex + marker.length);
    }

    const candidatePaths = [resolvedFromGalleryFile, resolvedFromGalleryRoot];
    for (const candidatePath of candidatePaths) {
      const projectRelativePath = candidatePath.startsWith(process.cwd())
        ? candidatePath.slice(process.cwd().length + 1)
        : candidatePath.replace(/^\/?/, '');

      if (projectRelativePath.startsWith('src/assets/uploaded_images/')) {
        return projectRelativePath.replace('src/assets/uploaded_images/', '');
      }
    }

    return normalized.replace(/^\.?\/?/, '');
  })();

  return {
    relativePath,
    baseName: path.basename(relativePath),
  };
}

function resolveImageMetadata(src: string): ImageMetadata | undefined {
  const { relativePath, baseName } = normalizeImageRef(src);
  return imageByRelativePath.get(relativePath) || imageByBaseName.get(baseName);
}

const selectedGallery = galleryEntries.find(entry => entry.id === gallery);
const selectedImages = Array.isArray(selectedGallery?.images)
  ? selectedGallery.images
  : [];

const resolvedImages = selectedImages.reduce<ResolvedGalleryImage[]>(
  (acc, entry, index) => {
    const metadata = resolveImageMetadata(entry.src);
    if (!metadata) return acc;

    acc.push({
      image: metadata,
      alt: (entry.alt || '').trim() || `Gallery image ${index + 1}`,
      ...(entry.caption ? { caption: entry.caption } : {}),
    });

    return acc;
  },
  [],
);

const resolvedHeading = heading || selectedGallery?.title || 'Image gallery';
const showMissingState =
  !selectedGallery || resolvedImages.length === 0 || loadError !== '';
---

{
  showMissingState ? (
    <section class="mdx-image-gallery mdx-image-gallery--empty">
      <p class="mdx-image-gallery__message">
        {loadError
          ? `Gallery could not be loaded: ${loadError}`
          : `Gallery "${gallery}" is empty or has no valid images.`}
      </p>
    </section>
  ) : (
    <section
      class="mdx-image-gallery"
      data-mdx-image-gallery
      data-at-start="true"
      data-at-end="false"
      style={`--mdx-gallery-image-height-mobile:${resolvedImageHeightMobile};--mdx-gallery-image-height-desktop:${resolvedImageHeightDesktop};`}
    >
      <div class="mdx-image-gallery__head">
        {showHeading ? (
          <h3 class="mdx-image-gallery__heading">{resolvedHeading}</h3>
        ) : (
          <span aria-hidden="true" />
        )}
        <div
          class="mdx-image-gallery__controls"
          aria-label="Scroll gallery images"
        >
          <button
            type="button"
            class="mdx-image-gallery__button"
            data-scroll-direction="left"
            aria-label="Scroll gallery left"
          >
            <span aria-hidden="true">&#8592;</span>
          </button>
          <button
            type="button"
            class="mdx-image-gallery__button"
            data-scroll-direction="right"
            aria-label="Scroll gallery right"
          >
            <span aria-hidden="true">&#8594;</span>
          </button>
        </div>
      </div>

      <div class="mdx-image-gallery__viewport-shell">
        <div class="mdx-image-gallery__viewport" tabindex="0">
          <ul class="mdx-image-gallery__track">
            {resolvedImages.map((item, idx) => (
              <li class="mdx-image-gallery__item">
                <figure class="mdx-image-gallery__figure">
                  {linkMode === 'full-image' ? (
                    <a
                      href={item.image.src}
                      class="mdx-image-gallery__image-link"
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label="Open full image"
                    >
                      <Image
                        src={item.image}
                        alt={item.alt}
                        loading="lazy"
                        widths={[240, 320, 480, 640, 768, 960]}
                        sizes="(min-width: 768px) and (orientation: landscape) 18rem, 72vw"
                        class="mdx-image-gallery__image"
                      />
                    </a>
                  ) : linkMode === 'lightbox' ? (
                    <button
                      type="button"
                      class="mdx-image-gallery__image-link mdx-image-gallery__image-lightbox-btn"
                      aria-label="Open image in lightbox"
                      data-lightbox-index={idx}
                    >
                      <Image
                        src={item.image}
                        alt={item.alt}
                        loading="lazy"
                        widths={[240, 320, 480, 640, 768, 960]}
                        sizes="(min-width: 768px) and (orientation: landscape) 18rem, 72vw"
                        class="mdx-image-gallery__image"
                      />
                    </button>
                  ) : (
                    <Image
                      src={item.image}
                      alt={item.alt}
                      loading="lazy"
                      widths={[240, 320, 480, 640, 768, 960]}
                      sizes="(min-width: 768px) and (orientation: landscape) 18rem, 72vw"
                      class="mdx-image-gallery__image"
                    />
                  )}
                  {showCaptions && item.caption ? (
                    <figcaption class="mdx-image-gallery__caption">
                      {item.caption}
                    </figcaption>
                  ) : null}
                </figure>
              </li>
            ))}
          </ul>
        </div>
      </div>

      {linkMode === 'lightbox' ? (
        <div class="mdx-image-gallery__lightbox" tabindex="-1" hidden>
          <div
            class="mdx-image-gallery__lightbox-overlay"
            data-lightbox-close
          />
          <figure class="mdx-image-gallery__lightbox-figure">
            <img class="mdx-image-gallery__lightbox-img" alt="" />
            <figcaption class="mdx-image-gallery__lightbox-caption" />
            <button
              type="button"
              class="mdx-image-gallery__lightbox-close"
              aria-label="Close image"
            >
              &times;
            </button>
          </figure>
        </div>
      ) : null}
    </section>
  )
}

<script is:inline>
  document.querySelectorAll('[data-mdx-image-gallery]').forEach(root => {
    const viewport = root.querySelector('.mdx-image-gallery__viewport');
    if (!viewport) return;

    const updateEdgeState = () => {
      const maxScrollLeft = viewport.scrollWidth - viewport.clientWidth;
      const atStart = viewport.scrollLeft <= 2;
      const atEnd = maxScrollLeft - viewport.scrollLeft <= 2;

      root.setAttribute('data-at-start', String(atStart));
      root.setAttribute('data-at-end', String(atEnd));
    };

    updateEdgeState();
    viewport.addEventListener('scroll', updateEdgeState, { passive: true });
    window.addEventListener('resize', updateEdgeState);

    viewport.addEventListener('keydown', event => {
      if (event.key !== 'ArrowLeft' && event.key !== 'ArrowRight') return;
      event.preventDefault();
      const direction = event.key === 'ArrowLeft' ? -1 : 1;
      const amount = Math.round(viewport.clientWidth * 0.85);
      viewport.scrollBy({ left: direction * amount, behavior: 'smooth' });
    });

    root.querySelectorAll('[data-scroll-direction]').forEach(button => {
      button.addEventListener('click', () => {
        const direction =
          button.getAttribute('data-scroll-direction') === 'left' ? -1 : 1;
        const amount = Math.round(viewport.clientWidth * 0.85);
        viewport.scrollBy({ left: direction * amount, behavior: 'smooth' });
      });
    });

    // Lightbox logic
    const lightbox = root.querySelector('.mdx-image-gallery__lightbox');
    if (lightbox) {
      const images = Array.from(
        root.querySelectorAll('.mdx-image-gallery__image-lightbox-btn'),
      );
      const imgEl = lightbox.querySelector('.mdx-image-gallery__lightbox-img');
      const captionEl = lightbox.querySelector(
        '.mdx-image-gallery__lightbox-caption',
      );
      const closeBtn = lightbox.querySelector(
        '.mdx-image-gallery__lightbox-close',
      );
      const overlay = lightbox.querySelector(
        '.mdx-image-gallery__lightbox-overlay',
      );
      const figures = Array.from(
        root.querySelectorAll('.mdx-image-gallery__figure'),
      );

      let currentIdx = null;

      function openLightbox(idx) {
        currentIdx = idx;
        const btn = images[idx];
        const img = btn.querySelector('img');
        imgEl.src = img.src.replace(/w=\d+/, 'w=1600'); // try to get largest version
        imgEl.alt = img.alt;
        // Try to get caption
        let caption = '';
        const fig = figures[idx];
        if (fig) {
          const cap = fig.querySelector('.mdx-image-gallery__caption');
          if (cap) caption = cap.textContent;
        }
        captionEl.textContent = caption || '';
        lightbox.hidden = false;
        lightbox.focus();
        document.body.style.overflow = 'hidden';
      }

      function closeLightbox() {
        lightbox.hidden = true;
        imgEl.src = '';
        imgEl.alt = '';
        captionEl.textContent = '';
        document.body.style.overflow = '';
        currentIdx = null;
      }

      images.forEach((btn, idx) => {
        btn.addEventListener('click', () => openLightbox(idx));
      });
      closeBtn.addEventListener('click', closeLightbox);
      overlay.addEventListener('click', closeLightbox);
      lightbox.addEventListener('keydown', e => {
        if (e.key === 'Escape') closeLightbox();
      });
      // Trap focus inside lightbox
      lightbox.addEventListener('focusout', e => {
        if (!lightbox.hidden && !lightbox.contains(e.relatedTarget)) {
          e.preventDefault();
          lightbox.focus();
        }
      });
    }
  });
</script>

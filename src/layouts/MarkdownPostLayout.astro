---
import BaseLayout from './BaseLayout.astro';
import '../styles/md-post-layout.css';
const { frontmatter, lastUpdated, prevpost, nextpost, slug } = Astro.props;
const dateOptions = {
  year: 'numeric' as const,
  month: 'long' as const,
  day: 'numeric' as const,
};
const formattedPublishDate = new Date(frontmatter.pubDate).toLocaleDateString(
  'en-UK',
  dateOptions,
);
const formattedUpdatedDate = lastUpdated
  ? new Date(lastUpdated).toLocaleString('en-GB', {
      year: 'numeric' as const,
      month: 'long' as const,
      day: 'numeric' as const,
      hour: '2-digit' as const,
      minute: '2-digit' as const,
    })
  : null;
const showUpdatedDate =
  lastUpdated &&
  new Date(lastUpdated).getTime() > new Date(frontmatter.pubDate).getTime();
---

<BaseLayout frontmatter={frontmatter} prevpost={prevpost} nextpost={nextpost}>
  <section class="post-layout content-padding">
    <h2 class="post-layout__title">{frontmatter.title}</h2>
    <div class="post-layout__meta">
      Published
      {
        frontmatter.category ? (
          <>
            {' '}
            in{' '}
            <a
              href={`/categories/${encodeURIComponent(frontmatter.category.toLowerCase())}/`}
              class="post-layout__meta-category"
            >
              {frontmatter.category}
            </a>
          </>
        ) : null
      }
      on {formattedPublishDate}
    </div>
    {
      Array.isArray(frontmatter.tags) && frontmatter.tags.length > 0 ? (
        <div class="post-layout__tags">
          {frontmatter.tags.map(tag => (
            <a
              href={`/tags/${encodeURIComponent(tag.toLowerCase())}/`}
              class="post-layout__tag-chip"
            >
              #{tag}
            </a>
          ))}
        </div>
      ) : null
    }
    {
      showUpdatedDate ? (
        <div class="post-layout__meta-updated">
          Updated on {formattedUpdatedDate}
        </div>
      ) : null
    }
    <div class="post-layout__content">
      <slot />
    </div>
  </section>
  <nav class="post-navigation content-padding">
    <div class="post-navigation__item post-navigation__prev">
      {
        prevpost ? (
          <a
            class="post-navigation__link"
            href={`/posts/${prevpost.id}/`}
            aria-label="Previous post"
          >
            &lt;&lt; {prevpost.data.title}
          </a>
        ) : (
          <span class="post-navigation__placeholder" aria-hidden="true">
            &nbsp;
          </span>
        )
      }
    </div>
    <div class="post-navigation__item post-navigation__next">
      {
        nextpost ? (
          <a
            class="post-navigation__link"
            href={`/posts/${nextpost.id}/`}
            aria-label="Next post"
          >
            {nextpost.data.title} &gt;&gt;
          </a>
        ) : (
          <span class="post-navigation__placeholder" aria-hidden="true">
            &nbsp;
          </span>
        )
      }
    </div>
  </nav>
</BaseLayout>

{
  "name": "hellostu--xyz",
  "type": "module",
  "version": "2.0.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "npm run prebuild && astro dev",
    "start": "astro dev",
    "prebuild": "node src/scripts/pre-build-sveltia-cms-catches.js && ts-node src/scripts/image-generation/generate-og-images.ts",
    "prebuild:clean": "node src/scripts/pre-build-sveltia-cms-catches.js --clean && ts-node src/scripts/image-generation/generate-og-images.ts",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "generate:og": "ts-node src/scripts/image-generation/generate-og-images.ts",
    "generate:preview": "ts-node src/scripts/image-generation/generate-preview-images.ts",
    "generate:recommendations": "node src/scripts/recommendations.mjs",
    "generate:recommendations:test": "node src/scripts/recommendations.mjs --test"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@google/generative-ai": "^0.24.1",
    "@sveltia/cms": "0.152.5",
    "astro": "^6.1.5",
    "astro-font": "1.1.0",
    "astro-icon": "1.1.5",
    "astro-imagetools": "0.9.0",
    "astro-seo": "1.1.0",
    "astro-social-share": "2.2.0",
    "firebase": "12.12.0",
    "firebase-admin": "13.8.0",
    "firebase-functions": "7.2.5",
    "fs-extra": "^11.3.4",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.0",
    "puppeteer": "^24.40.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sanitize-html": "^2.17.0",
    "sharp": "^0.34.5",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "ts-node": "^10.9.2"
  }
}
